{
  "name": "@xdarkicex/libravdb-contracts",
  "version": "2.0.22",
  "description": "LibraVDB IPC protocol types — protobuf-es generated",
  "type": "module",
  "main": "./gen/js/libravdb/ipc/v1/rpc_pb.js",
  "types": "./gen/js/libravdb/ipc/v1/rpc_pb.d.ts",
  "exports": {
    ".": {
      "import": "./gen/js/libravdb/ipc/v1/rpc_pb.js",
      "types": "./gen/js/libravdb/ipc/v1/rpc_pb.d.ts"
    },
    "./client": {
      "import": "./gen/js/libravdb/ipc/v1/rpc_connect.js",
      "types": "./gen/js/libravdb/ipc/v1/rpc_connect.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "gen/js/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "buf generate",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.7.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.69.0",
    "@bufbuild/protoc-gen-es": "^2.10.0",
    "@connectrpc/protoc-gen-connect-es": "^1.7.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}